#!/bin/sh
branch=$(git branch --show-current)
if [ "$branch" = "main" ]; then
  echo "ERROR: Direct commits to main are not allowed. Create a branch first."
  exit 1
fi

# File-size check on staged Dart/Go files. Growth-based: only blocks a file
# that is over the limit AND longer than it was at HEAD, so pre-existing
# large files are grandfathered and can still be edited — they just can't
# get any bigger. Use --no-verify for a deliberate exception.
size_limit=300
staged_code=$(git diff --cached --name-only | grep -E '\.(dart|go)$')
if [ -n "$staged_code" ]; then
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    staged_lines=$(git show ":$f" 2>/dev/null | wc -l)
    head_lines=$(git show "HEAD:$f" 2>/dev/null | wc -l)
    if [ "$staged_lines" -gt "$size_limit" ] && [ "$staged_lines" -gt "$head_lines" ]; then
      echo "ERROR: $f is $staged_lines lines (limit $size_limit) and grew from $head_lines lines at HEAD."
      echo "  Split the file, or commit with --no-verify if the growth is intentional."
      exit 1
    fi
  done <<EOF
$staged_code
EOF
fi

# Flutter checks on staged Dart or Flutter config files
staged_flutter=$(git diff --cached --name-only | grep -E '^universal/.*(\.dart$|pubspec\.(yaml|lock)$|analysis_options\.yaml$)')
if [ -n "$staged_flutter" ]; then
  echo "Flutter files staged — running tests, analysis, and coverage checks..."
  (cd universal && flutter test --concurrency=4 --reporter=compact --coverage) || exit 1
  (cd universal && flutter analyze) || exit 1

  command -v diff-cover >/dev/null 2>&1 || {
    echo "ERROR: diff-cover not found. Install it with: pipx install diff-cover"
    exit 1
  }

  COVERAGE_THRESHOLD=95.0 python3 - <<'PYEOF' || exit 1
import os

THRESHOLD = float(os.environ["COVERAGE_THRESHOLD"])
EXCLUDE = {"lib/main.dart"}
LCOV_PATH = "universal/coverage/lcov.info"

try:
    with open(LCOV_PATH) as f:
        lcov_lines = f.readlines()
except FileNotFoundError:
    print(f"ERROR: {LCOV_PATH} not found — did `flutter test --coverage` run?")
    raise SystemExit(1)

records = []
name = lf = lh = 0
for line in lcov_lines:
    line = line.strip()
    if line.startswith("SF:"):
        name = line[3:]
    elif line.startswith("LF:"):
        lf = int(line[3:])
    elif line.startswith("LH:"):
        lh = int(line[3:])
    elif line == "end_of_record":
        records.append((name, lh, lf))
        name, lf, lh = "", 0, 0

total_hit = total_found = 0
gaps = []
for rel, lh, lf in records:
    if rel in EXCLUDE:
        continue
    total_hit += lh
    total_found += lf
    if lf and lh < lf:
        gaps.append((100 * lh / lf, rel, lh, lf))

if total_found == 0:
    print(f"ERROR: no coverage data found in {LCOV_PATH}")
    raise SystemExit(1)

pct = 100 * total_hit / total_found
print(f"Global line coverage: {pct:.1f}% ({total_hit}/{total_found}), threshold {THRESHOLD}%")
if pct < THRESHOLD:
    print("ERROR: global coverage below threshold. Files with gaps:")
    for gpct, rel, lh, lf in sorted(gaps):
        print(f"  {gpct:5.1f}%  {lh}/{lf}  {rel}")
    raise SystemExit(1)
PYEOF

  # diff-cover matches lcov paths against `git diff` paths, which are always
  # repo-root-relative — rewrite the lcov.info's universal/-relative SF: paths
  # to match before invoking it from the repo root. Cleanup is done inline
  # (not left to the trap) since the infra-checks block below registers its
  # own EXIT trap, which would silently replace this one in POSIX sh (traps
  # don't stack) if a single commit touched both Dart and deploy/ files. The
  # trap is still set for the duration of the diff-cover call itself, to
  # cover the SIGINT/SIGTERM window, then cleared right after.
  lcov_root=$(mktemp --suffix=.info)
  sed 's/^SF:/SF:universal\//' universal/coverage/lcov.info > "$lcov_root"
  trap 'rm -f "$lcov_root"' EXIT INT TERM
  diff-cover "$lcov_root" \
    --compare-branch=HEAD --ignore-unstaged \
    --fail-under=100 --show-uncovered
  diff_cover_status=$?
  rm -f "$lcov_root"
  trap - EXIT INT TERM
  [ $diff_cover_status -eq 0 ] || exit 1
fi

# YAML/manifest checks on staged deploy/, .github/, or .yamllint.yml files
staged_lint=$(git diff --cached --name-only | grep -E '^(deploy/|\.github/|\.yamllint\.yml$)')
staged_deploy=$(git diff --cached --name-only | grep '^deploy/' | grep -vE '\.(md|txt)$')
if [ -n "$staged_lint" ]; then
  echo "Infrastructure files staged — running manifest linting..."

  for cmd in yamllint kustomize kubeconform; do
    command -v "$cmd" >/dev/null 2>&1 || {
      echo "ERROR: $cmd not found. Install it before committing infrastructure changes."
      exit 1
    }
  done

  # Lint all staged infra files. Skip argocd-install.yaml and sealedsecret.yaml
  # explicitly — yamllint's ignore: block only applies to directory walks, not
  # per-file invocations.
  while IFS= read -r f; do
    [ -z "$f" ] && continue
    echo "$f" | grep -qE '\.(md|txt)$' && continue
    echo "$f" | grep -qE 'argocd-install\.yaml|sealedsecret\.yaml' && continue
    yamllint "$f" || exit 1
  done <<EOF
$staged_lint
EOF

  # kustomize and kubeconform only apply when deploy/ files are staged
  if [ -n "$staged_deploy" ]; then
    # Set up temp files and trap immediately so any early exit cleans up.
    tmp=$(mktemp --suffix=.yaml)
    kc_out=$(mktemp --suffix=.json)
    trap 'rm -f "$tmp" "$kc_out"' EXIT INT TERM

    # Stash unstaged deploy/ changes so validations run against what will be
    # committed, not the full working tree. Use rev-parse to reliably detect
    # whether a stash entry was created, and only pop if one was.
    stash_before=$(git rev-parse --verify refs/stash 2>/dev/null || true)
    stash_err=$(git stash push --keep-index --include-untracked --quiet -- deploy/ 2>&1)
    stash_rc=$?
    stash_after=$(git rev-parse --verify refs/stash 2>/dev/null || true)
    if [ "$stash_before" != "$stash_after" ]; then
      trap 'rm -f "$tmp" "$kc_out"; git stash pop --quiet || echo "WARNING: git stash pop failed — check git stash list and clean up manually"' EXIT INT TERM
    elif [ $stash_rc -ne 0 ]; then
      echo "ERROR: git stash push failed: $stash_err"
      exit 1
    fi

    : > "$tmp"
    for dir in deploy/bootstrap deploy/services/hello deploy/infra/sealed-secrets deploy/infra/duckdns-updater; do
      [ -d "$dir" ] || continue
      kustomize build "$dir" >> "$tmp" || exit 1
      echo "---" >> "$tmp"
    done
    for f in deploy/apps/*.yaml; do
      [ -e "$f" ] || continue
      cat "$f" >> "$tmp"
      echo "---" >> "$tmp"
    done
    kubeconform \
      -strict \
      -ignore-missing-schemas \
      -skip CustomResourceDefinition \
      -output json \
      -verbose \
      -schema-location default \
      -schema-location 'https://raw.githubusercontent.com/datreeio/CRDs-catalog/1de95b7e9cb737ba46b14fa5a033fee2e47d90a3/{{.Group}}/{{.ResourceKind}}_{{.ResourceAPIVersion}}.json' \
      "$tmp" > "$kc_out" || { cat "$kc_out"; exit 1; }
    python3 - "$kc_out" <<'PYEOF' || exit 1
import sys, json
with open(sys.argv[1]) as f:
    records = json.load(f).get('resources', [])
if not records:
    print('ERROR: kubeconform produced no output — validation did not run')
    sys.exit(1)
bad = [r for r in records if r.get('status') not in ('statusValid', 'statusSkipped')]
if bad:
    print('ERROR: non-valid resources:')
    for r in bad:
        print(f'  {r["status"]} {r.get("apiVersion","")} {r.get("kind","")}/{r.get("name","?")}')
    sys.exit(1)
valid = [r for r in records if r.get('status') == 'statusValid']
print(f'kubeconform: {len(valid)} resources validated')
PYEOF
  fi
fi
