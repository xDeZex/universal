@startuml
!include <C4/C4_Context.puml>

title System Context: Universal

Person(oliver, "Oliver", "Developer and sole user. Writes code, uses the app, views dashboards.")

System(universal, "Universal", "Flutter checklist and gym tracker with self-hosted Go services on a Raspberry Pi 4B.")

System_Ext(github, "GitHub + GHCR", "Source control, GitHub Actions CI, and container image registry.")
System_Ext(duckdns, "DuckDNS", "Dynamic DNS — keeps a hostname pointed at the Pi's public IP.")

Rel(oliver, github, "Pushes code, reviews PRs", "HTTPS/git")
Rel(oliver, universal, "Uses app and monitors dashboards", "Android / HTTPS")
Rel(github, universal, "CI pushes images; ArgoCD syncs manifests to cluster", "HTTPS")
Rel(universal, duckdns, "Updates public IP to keep hostname reachable", "HTTPS/API")

Lay_R(universal, github)
Lay_D(universal, duckdns)

LAYOUT_WITH_LEGEND()
@enduml
